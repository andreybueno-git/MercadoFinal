  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 22
    m_FontStyle: 1
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\u2022 Ande pelo mercado com WASD / setas.\n\u2022 Clientes entram querendo
    um produto (veja o bal\xE3o).\n\u2022 Chegue perto e aperte E/Espa\xE7o para
    ATENDER (precisa do produto na prateleira).\n\u2022 Aperte E perto de uma PRATELEIRA
    para REPOR do estoque.\n\u2022 Aperte E perto do FUNDO (caixas) para COMPRAR
    de fornecedores.\n\u2022 Produtos perec\xEDveis VENCEM \u2014 venda antes ou
    perde reputa\xE7\xE3o.\n\u2022 Cada n\xEDvel tem uma META de dinheiro. Bata a
    meta antes de acabar o tempo!\n\u2022 S\xE3o 3 n\xEDveis; o dinheiro e a reputa\xE7\xE3o
    passam de um pro outro.\n\u2022 Se o dinheiro zerar ou a reputa\xE7\xE3o despencar:
    GAME OVER."
